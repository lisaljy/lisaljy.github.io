---
const fullName = "LISA LIAO JINGYI";
const navItems = [
  { label: "About", href: "/" },
  { label: "Project", href: "/project/" },
  { label: "Publication", href: "/publication/" },
  { label: "Life", href: "/life/" }
];

const communityPartners = [
  {
    name: "One Plus One Disability Group",
    href: "http://www.yijiayi.org.cn/en/index.php?catid=14",
    description:
      "A disabled people-led organization advancing disability rights, employment, and inclusive technology innovation."
  },
  {
    name: "Yuanzhong Family & Community Development Service Center",
    href: "https://www.bjyuanzhong.org.cn/",
    description:
      "An NGO providing anti-gender-based violence training and support for women."
  },
  {
    name: "KAIYUANSHE",
    href: "https://kaiyuanshe.cn/",
    description:
      "A social enterprise dedicated to promoting open-source culture and community development."
  }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Lisa Liao Jingyi studies how technologies are imagined, negotiated, and lived with grassroots communities."
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{fullName} | Personal Website</title>
  </head>
  <body>
    <a class="skip-link" href="#page-title">Skip to main content</a>
    <button
      class="accessibility-toggle"
      type="button"
      aria-pressed="false"
      aria-label="Toggle high contrast mode"
    >
      High contrast
    </button>
    <main class="page-shell">
      <header class="site-header">
        <nav aria-label="Main navigation">
          {
            navItems.map((item) => (
              <a href={item.href}>{item.label}</a>
            ))
          }
        </nav>
      </header>

      <section class="hero" aria-labelledby="page-title">
        <p class="keywords">Technology · Communities · Ordinary Life</p>
        <h1 id="page-title">{fullName}</h1>
        <p class="tagline">
          I study how technologies are imagined, negotiated, and lived with grassroots
          communities.
        </p>
        <a class="contact-button" href="mailto:liaojingyi-lisa@outlook.com">Contact</a>
      </section>

      <div class="content-flow">
      <section class="section bio-section" aria-labelledby="about-title">
          <h2 id="about-title">About</h2>
          <p>
            I am a participatory action researcher and PhD candidate at the Wee Kim Wee School
            of Communication and Information, Nanyang Technological University. My work sits at
            the intersection of Science, Technology and Society, disability cultures, and gender
            equality. Before my PhD, I received my master's degree in Computer Science from
            Tsinghua University and worked as a Corporate Social Responsibility Manager at
            ByteDance, focusing on digital inclusion strategy.
          </p>
        </section>

        <section class="section research-section" aria-labelledby="research-title">
          <h2 id="research-title">Participatory Action Research</h2>
          <p>
            My research is grounded in long-term engagement with grassroots communities in China,
            especially through Tech for Development projects with:
          </p>

          <div class="partner-grid">
            {
              communityPartners.map((partner) => (
                <article>
                  <h3>
                    <a
                      href={partner.href}
                      target="_blank"
                      rel="noreferrer"
                      aria-label={`${partner.name} (opens in a new tab)`}
                    >
                      {partner.name}
                    </a>
                  </h3>
                  <p>{partner.description}</p>
                </article>
              ))
            }
          </div>
        </section>

        <section class="section beyond-section" aria-labelledby="beyond-title">
          <h2 id="beyond-title">Beyond Research</h2>
          <p>
            Outside academia, I explore contact improvisation, embodied media, and alternative
            ways of living as everyday practices of sensing, relating, and imagining otherwise.
          </p>
        </section>
      </div>
    </main>
    <script>
      const contrastButton = document.querySelector(".accessibility-toggle");
      const contrastPreference = localStorage.getItem("high-contrast") === "true";

      const setHighContrast = (enabled) => {
        document.body.classList.toggle("high-contrast", enabled);
        contrastButton?.setAttribute("aria-pressed", String(enabled));
        localStorage.setItem("high-contrast", String(enabled));
      };

      setHighContrast(contrastPreference);

      contrastButton?.addEventListener("click", () => {
        setHighContrast(!document.body.classList.contains("high-contrast"));
      });
    </script>
  </body>
</html>

<style>
  :root {
    color: #1f2933;
    background: #faf8f4;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
  }

  a {
    color: inherit;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  a:hover {
    color: #8a4a36;
  }

  .page-shell {
    width: min(1180px, calc(100% - 44px));
    margin: 0 auto;
    padding: 30px 0 80px;
  }

  .site-header {
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 10px 22px;
  }

  nav a {
    color: #3d4652;
    font-size: 1rem;
    text-decoration: none;
  }

  nav a:hover {
    color: #8a4a36;
  }

  a:focus-visible {
    outline: 2px solid rgba(138, 74, 54, 0.68);
    outline-offset: 4px;
  }

  .skip-link {
    position: absolute;
    left: 16px;
    top: 16px;
    z-index: 100;
    transform: translateY(-140%);
    border-radius: 6px;
    padding: 10px 12px;
    background: #faf8f4;
    color: #14213d;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 12px 24px rgba(20, 33, 61, 0.14);
  }

  .skip-link:focus-visible {
    transform: translateY(0);
  }

  .accessibility-toggle {
    position: fixed;
    right: max(22px, calc((100vw - 1180px) / 2));
    bottom: 18px;
    z-index: 90;
    min-height: 38px;
    border: 2px solid rgba(20, 33, 61, 0.2);
    border-radius: 8px;
    padding: 8px 11px;
    background: rgba(250, 248, 244, 0.92);
    color: #14213d;
    cursor: pointer;
    font-size: 0.78rem;
    font-weight: 800;
    box-shadow: 0 12px 24px rgba(20, 33, 61, 0.12);
  }

  .accessibility-toggle[aria-pressed="true"] {
    background: #000;
    color: #fff200;
    border-color: #fff200;
  }

  body.high-contrast {
    background: #000;
    color: #fff;
  }

  body.high-contrast *,
  body.high-contrast *::before,
  body.high-contrast *::after {
    color: #fff !important;
    border-color: #fff !important;
    background-color: transparent;
  }

  body.high-contrast .content-flow,
  body.high-contrast .content-flow::before {
    background: #000 !important;
  }

  body.high-contrast a,
  body.high-contrast .keywords,
  body.high-contrast .accessibility-toggle {
    color: #fff200 !important;
  }

  body.high-contrast .accessibility-toggle {
    background: #000 !important;
  }

  body.high-contrast a:focus-visible,
  body.high-contrast button:focus-visible {
    outline-color: #00e5ff;
  }

  .hero {
    min-height: calc(100vh - 104px);
    max-width: 980px;
    display: grid;
    align-content: center;
    margin: 0 auto;
    padding: clamp(52px, 8vw, 88px) 0 clamp(72px, 10vw, 112px);
    transform: translateX(clamp(28px, 3.4vw, 62px));
  }

  .content-flow {
    position: relative;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    margin-top: 22px;
    margin-bottom: -80px;
    padding: 96px max(22px, calc((100vw - 1120px) / 2)) 172px;
    background: #ece5dc;
  }

  .content-flow::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: -170px;
    height: 170px;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(250, 248, 244, 0) 0%,
      rgba(236, 229, 220, 0.34) 30%,
      #ece5dc 72%
    );
  }

  .keywords {
    margin: 0 0 18px;
    color: #8a4a36;
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    font-weight: 700;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 980px;
    margin-bottom: 26px;
    color: #14213d;
    font-size: clamp(3rem, 7vw, 5.25rem);
    line-height: 1.04;
    letter-spacing: 0;
    white-space: nowrap;
  }

  .tagline {
    max-width: 820px;
    margin-bottom: 0;
    color: #2f3a45;
    font-size: clamp(1.28rem, 2.6vw, 2rem);
    line-height: 1.38;
  }

  .contact-button {
    width: fit-content;
    margin-top: 24px;
    border: 1px solid rgba(138, 74, 54, 0.28);
    border-radius: 999px;
    padding: 8px 18px;
    color: #8a4a36;
    font-size: 0.98rem;
    font-weight: 750;
    text-decoration: none;
    transition:
      background 150ms ease,
      border-color 150ms ease,
      color 150ms ease;
  }

  .contact-button:hover {
    border-color: rgba(138, 74, 54, 0.62);
    background: rgba(138, 74, 54, 0.07);
    color: #6f3827;
  }

  .section {
    max-width: 980px;
    margin: 0 auto;
    padding: clamp(26px, 3.8vw, 42px) 0;
    transform: translateX(clamp(28px, 3.4vw, 62px));
  }


  h2 {
    max-width: 820px;
    margin-bottom: 10px;
    color: #14213d;
    font-size: clamp(1.55rem, 3vw, 2.15rem);
    line-height: 1.22;
    letter-spacing: 0;
  }

  .section > p {
    max-width: 820px;
    margin-bottom: 0;
    color: #2f3a45;
    font-size: clamp(1.02rem, 1.55vw, 1.14rem);
    line-height: 1.54;
  }

  .partner-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    margin-top: 10px;
    max-width: 820px;
  }

  .partner-grid article {
    padding: 8px 0;
    background: transparent;
  }

  .partner-grid h3 {
    margin-bottom: 5px;
    color: #14213d;
    font-size: 1.05rem;
    line-height: 1.28;
  }

  .content-flow a {
    color: #8a4a36;
    font-weight: 750;
    text-decoration-line: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .content-flow a:hover {
    color: #6f3827;
  }

  .partner-grid p {
    margin-bottom: 0;
    color: #4b5563;
    font-size: 0.96rem;
    line-height: 1.58;
  }

  @media (max-width: 720px) {
    .page-shell {
      width: min(100% - 28px, 1040px);
      padding-top: 22px;
    }

    .site-header {
      justify-content: flex-end;
    }

    .accessibility-toggle {
      right: 14px;
    }

    nav {
      justify-content: flex-end;
      gap: 10px 16px;
    }

    .hero {
      min-height: calc(100vh - 88px);
      padding: 48px 0 64px;
      transform: none;
    }

    .keywords {
      margin-bottom: 14px;
      font-size: 0.98rem;
    }

    h1 {
      margin-bottom: 20px;
      font-size: clamp(2.45rem, 13vw, 3.2rem);
      line-height: 1;
      white-space: normal;
    }

    .tagline {
      font-size: 1.24rem;
      line-height: 1.42;
    }

    .section {
      padding: 40px 0;
      transform: none;
    }

    h2 {
      font-size: 1.48rem;
    }

    .section > p {
      font-size: 1rem;
      line-height: 1.62;
    }

    .partner-grid {
      margin-top: 18px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
  }
</style>
