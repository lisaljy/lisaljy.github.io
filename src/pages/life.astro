---
const title = "Life";

const bodyImages = [
  [
    {
      src: "/pic/1.JPG",
      width: 1638,
      height: 2469,
      alt: "Two performers in a dark studio, connected at the hips by a piece of red fabric; one supports their body on hands and feet while the other leans backward across them with one leg extended.",
      credit: "Photo Credit: @Pengyu Contemporary Dance"
    }
  ],
  [
    {
      src: "/pic/2.JPG",
      width: 4032,
      height: 3024,
      alt: "Two performers in a dark studio, seated and leaning into each other while extending their arms in opposite directions, with a small red ball held between their bodies.",
      credit: "Photo Credit: @Pengyu Contemporary Dance"
    }
  ],
  [
    {
      src: "/pic/3.JPG",
      width: 3000,
      height: 4000,
      alt: "A performer bending forward inside a light-colored installation made of thin intersecting lines.",
      credit: "Photo Credit: @Pengyu Contemporary Dance"
    }
  ],
  [
    {
      src: "/pic/4.JPG",
      width: 3000,
      height: 4000,
      alt: "A performer standing inside a web-like installation of red threads, her head is squeezing a red ball toward the wall.",
      credit: "Photo Credit: @Pengyu Contemporary Dance"
    }
  ],
  [
    {
      src: "/pic/5.JPG",
      width: 4032,
      height: 3024,
      alt: "An intentionally upside-down image of two performers on a grassy riverbank: one lies along the grass holding a long bamboo pole across their body, while the other hangs from the pole with bent legs, making the river, trees, and sky appear inverted.",
      credit: "Photo Credit: @Pengyu Contemporary Dance"
    },
    {
      src: "/pic/6.JPG",
      width: 3685,
      height: 2764,
      alt: "A person bending backward on a grassy field, under a cloudy sky.",
      credit: "Photo Credit: @Pengyu Contemporary Dance"
    }
  ],
  [
    {
      src: "/pic/7.jpg",
      width: 3317,
      height: 4975,
      alt: "A performer inside a red-thread installation, reaching upward in a warm-toned indoor space.",
      credit: "Photo Credit: @AdaQi"
    }
  ],
  [
    {
      src: "/pic/8.jpg",
      width: 1865,
      height: 2611,
      alt: "A performer crouching low on the ground under purple and yellow lighting.",
      credit: "Photo Credit: @AdaQi"
    }
  ],
  [
    {
      src: "/pic/9.jpg",
      width: 2880,
      height: 2057,
      alt: "A dark seascape image showing a performer moving near the water with one arm raised.",
      credit: "Photo Credit: @AdaQi"
    }
  ],
  [
    {
      src: "/pic/10.jpg",
      width: 4726,
      height: 3192,
      alt: "A wide seascape showing a small figure standing alone in shallow water near the horizon.",
      credit: "Photo Credit: @AdaQi"
    }
  ],
  [
    {
      src: "/pic/11.jpg",
      width: 5082,
      height: 7631,
      alt: "A close-up portrait partially covered by translucent white fabric or netting.",
      credit: "Photo Credit: @Xuan"
    }
  ],
  [
    {
      src: "/pic/12.jpg",
      width: 5304,
      height: 7952,
      alt: "A black-and-white image of a performer standing in a light-filled structure, wrapped by fabric and lines on her head.",
      credit: "Photo Credit: @Xuan"
    }
  ],
  [
    {
      src: "/pic/13.jpg",
      width: 1280,
      height: 1919,
      alt: "An upside-down portrait of a person with a spider near their eye.",
      credit: "Photo Credit: @Xuan"
    }
  ],
  [
    {
      src: "/pic/14.jpg",
      width: 1280,
      height: 1919,
      alt: "A soft portrait of a person with short hair, wearing a white garment and a small spider on the shoulder.",
      credit: "Photo Credit: @Xuan"
    }
  ],
  [
    {
      src: "/pic/15.png",
      width: 1125,
      height: 627,
      alt: "A dark outdoor scene showing a person crouching near a white lion figure.",
      credit: "Photo Credit: @Chuanchuan"
    },
    {
      src: "/pic/16.png",
      width: 1125,
      height: 634,
      alt: "A night scene showing a performer crouching on a white bedsheet, facing a white lion statue in an outdoor grassy area.",
      credit: "Photo Credit: @Chuanchuan"
    }
  ]
];

const gatheringImageGroups = [
  [
    {
      src: "/pic/workshop-colorful-1.jpg",
      alt: "Close-up of two painted hands pressing onto a white mat, leaving red, blue, and purple marks during an outdoor color workshop.",
      credit: "Color workshop · Credit: @Xuan"
    },
    {
      src: "/pic/workshop-colorful-2.jpg",
      alt: "Two participants using their painted bodies and hands to make marks on a large cloth spread across the grass during an outdoor movement and color workshop.",
      credit: "Color workshop · Credit: @Xuan"
    },
    {
      src: "/pic/workshop-colorful-3.jpg",
      alt: "A group of participants smiling at the camera on a large outdoor cloth covered with colorful paint, with paint marks on their faces, hands, and clothes.",
      credit: "Color workshop · Credit: @Xuan"
    }
  ],
  [
    {
      src: "/pic/workshop-line-1.jpg",
      alt: "A black-and-white workshop image showing several blurred figures moving with long lines in a dim room, creating a sense of motion and connection.",
      credit: "Line workshop · Credit: @Xiaochang"
    },
    {
      src: "/pic/workshop-line-2-normalized.jpg",
      alt: "A black-and-white workshop image of two blurred participants moving with a long line stretched between them.",
      credit: "Line workshop · Credit: @Xiaochang"
    },
    {
      src: "/pic/workshop-line-3.jpg",
      alt: "A black-and-white workshop image showing one participant seated on the floor while another figure dances nearby, with a long line crossing the space between them.",
      credit: "Line workshop · Credit: @Xiaochang"
    }
  ],
  [
    {
      src: "/pic/workshop-surface-1.jpg",
      alt: "A group of participants standing against a white wall, each holding a different leaning, reaching, or bending pose during a movement workshop.",
      credit: "Surface workshop · Credit: @Beijing CI"
    },
    {
      src: "/pic/workshop-surface-2.jpg",
      alt: "Several participants moving along a white wall in a workshop, bending, arching, and leaning as they explore different body shapes and directions.",
      credit: "Surface workshop · Credit: @Beijing CI"
    },
    {
      src: "/pic/workshop-surface-3.jpg",
      alt: "A line of participants against a white wall, each making a distinct full-body shape through bending, reaching, leaning, or stretching during a movement exercise.",
      credit: "Surface workshop · Credit: @Beijing CI"
    }
  ]
];

const carouselImages = [...bodyImages, ...bodyImages, ...bodyImages];
const initialCarouselIndex = bodyImages.length + 7;
const carouselSlots = carouselImages.map((slot, index) => ({
  index,
  isPriorityBodySlot: Math.abs(index - initialCarouselIndex) <= 1,
  isScreenReaderSlot: index >= bodyImages.length && index < bodyImages.length * 2,
  slot
}));
const bodyLightboxImages = bodyImages.flat();
const gatheringImages = gatheringImageGroups.flat();
const gatheringLabels = ["Color", "Line", "Surface"];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preload" as="image" href="/pic/8.jpg" />
    <link rel="preload" as="image" href="/pic/9.jpg" />
    <link rel="preload" as="image" href="/pic/10.jpg" />
    <title>{title} | LISA LIAO JINGYI</title>
  </head>
  <body>
    <a class="skip-link" href="#page-title">Skip to main content</a>
    <button
      class="accessibility-toggle"
      type="button"
      aria-pressed="false"
      aria-label="Toggle high contrast mode"
    >
      High contrast
    </button>
    <main class="page-shell">
      <header>
        <nav aria-label="Main navigation">
          <a href="/">About</a>
          <a href="/project/">Project</a>
          <a href="/publication/">Publication</a>
          <a href="/life/">Life</a>
        </nav>
      </header>

      <section class="life-hero" aria-labelledby="page-title">
        <h1 id="page-title">Fabric of life</h1>
        <p>
          I believe that the intuition of the body and the fragments of ordinary life can weave
          together another kinds of imagination rooted in care. Beyond academia, I continuously
          explore the body through contact improvisation and embodied media, and experiencing
          alternative ways of living. I view these practices as forms of self-reflexivity and
          expression. To see and feel the real person behind those abstract concepts.
        </p>
      </section>

      <section class="life-page" aria-label="Life fragments">
        <div class="life-content">
        <section
          class="life-section"
          id="body-as-practice"
          aria-labelledby="body-practice-title"
        >
          <div class="section-copy">
            <h2 id="body-practice-title">Body as Practice</h2>
            <p>
              Body for me is a way of expression. Some visual arts were co-created with
              photographers and directors; others came from informal field experiments. Across
              them, I am interested in how movement, stillness, exposure, and landscape can hold
              feelings that are difficult to explain in words.
            </p>
            <button class="video-work-button" type="button" data-open-video-work>
              <span>Selected Video Work</span>
              <span aria-hidden="true">+</span>
            </button>
          </div>

          <div class="carousel-shell">
            <button class="carousel-button carousel-prev" type="button" aria-label="Scroll images left">
              &lsaquo;
            </button>
            <p class="sr-only" id="carousel-status" aria-live="polite"></p>
            <div
              class="image-carousel is-positioning"
              tabindex="0"
              aria-label="Body as Practice image carousel"
            >
              {
                carouselSlots.map(({ slot, index, isPriorityBodySlot, isScreenReaderSlot }) => (
                    <figure
                      class={`carousel-slot ${slot.length > 1 ? "stacked-slot" : ""}`}
                      data-carousel-focus={index === initialCarouselIndex ? "true" : undefined}
                      aria-hidden={isScreenReaderSlot ? undefined : "true"}
                    >
                      {slot.map((image) => (
                        <button
                          class="carousel-image-button"
                          type="button"
                          tabindex={isScreenReaderSlot ? undefined : "-1"}
                          data-lightbox-src={image.src}
                          data-lightbox-alt={image.alt}
                          data-lightbox-credit={image.credit}
                          data-lightbox-gallery="body-practice"
                          data-lightbox-index={String(bodyLightboxImages.findIndex((item) => item.src === image.src))}
                          aria-label={image.alt}
                        >
                          <img
                            src={image.src}
                            alt=""
                            width={image.width}
                            height={image.height}
                            loading={isPriorityBodySlot ? "eager" : "lazy"}
                            fetchpriority={isPriorityBodySlot ? "high" : "auto"}
                            decoding="async"
                          />
                        </button>
                      ))}
                    </figure>
                ))
              }
            </div>
            <button class="carousel-button carousel-next" type="button" aria-label="Scroll images right">
              &rsaquo;
            </button>
          </div>
        </section>

        <section
          class="life-section gathering-section"
          id="body-as-gathering"
          aria-labelledby="body-gathering-title"
        >
          <div class="section-copy">
            <h2 id="body-gathering-title">Body as Gathering</h2>
            <p>
              Body can also become a reason to gather. These moments are less about performance
              and more about creating a shared space where people can move, improvise, connect
              with each other, and experiment with trust, boundaries, and presence.
            </p>
          </div>

          <div class="gathering-grid" aria-label="Body as Gathering images">
            {
              gatheringImageGroups.map((group, groupIndex) => (
                <figure class="gathering-image">
                  <button
                    class="gathering-image-button"
                    type="button"
                    data-lightbox-src={group[0].src}
                    data-lightbox-alt={group[0].alt}
                    data-lightbox-credit={group[0].credit}
                    data-lightbox-gallery={`body-gathering-${groupIndex}`}
                    data-lightbox-index="0"
                    aria-label={`${gatheringLabels[groupIndex]} workshop gallery, ${group.length} images`}
                  >
                    <img src={group[0].src} alt="" loading="lazy" />
                    <span class="gathering-overlay" aria-hidden="true">{gatheringLabels[groupIndex]}</span>
                  </button>
                  <div hidden>
                    {group.slice(1).map((image, index) => (
                      <button
                        type="button"
                        data-lightbox-src={image.src}
                        data-lightbox-alt={image.alt}
                        data-lightbox-credit={image.credit}
                        data-lightbox-gallery={`body-gathering-${groupIndex}`}
                        data-lightbox-index={String(index + 1)}
                        aria-label={`${gatheringLabels[groupIndex]} workshop image ${index + 2}: ${image.alt}`}
                      >
                        {image.alt}
                      </button>
                    ))}
                  </div>
                </figure>
              ))
            }
          </div>
        </section>

        <section
          class="life-section simulation-section"
          id="simulation-empathy-workshop"
          aria-labelledby="simulation-empathy-title"
        >
          <div class="section-copy">
            <h2 id="simulation-empathy-title">Empathy Simulation</h2>
            <p>
              This is a kind of workshop, an ongoing experiment in making inclusion-related issues
              easier to approach. It creates an invitation for participants to encounter unfamiliar
              experiences with curiosity and opens space where different ways of sensing, deciding,
              and navigating the world can be felt and discussed.
            </p>
            <p>
              These experiments began from my earlier work on gender-based violence prevention. I
              hope to expand this format toward disability and other topics shaped by stereotypes
              and assumptions.
            </p>
          </div>
        </section>

        <section
          class="life-section living-section"
          id="alternative-way-of-living"
          aria-labelledby="alternative-living-title"
        >
          <div class="section-copy">
            <h2 id="alternative-living-title">Alternative Way of Living</h2>
            <p>
              This section gathers my curiosity about how life is actually built: how people define
              safety and home, share resources and negotiate intimacy. These questions have led me
              to visit and document communities experimenting with other ways of living, from
              co-living spaces and rural self-sufficient projects to temporary worlds such as
              Burning Man and tech-optimist kingdoms. These fragments are part of how I explore what
              kind of life I want, and what forms of freedom and belonging are possible outside of
              default life.
            </p>
          </div>
        </section>

        </div>
      </section>
      <dialog class="image-lightbox" id="life-image-lightbox" aria-label="Enlarged life image">
        <button class="lightbox-close" type="button" aria-label="Close enlarged image">+</button>
        <button class="lightbox-nav lightbox-prev" type="button" aria-label="Previous image">&lsaquo;</button>
        <figure>
          <img src="" alt="" />
          <figcaption class="lightbox-credit"></figcaption>
        </figure>
        <button class="lightbox-nav lightbox-next" type="button" aria-label="Next image">&rsaquo;</button>
      </dialog>
      <dialog class="video-work-modal" id="gapping-modal" aria-labelledby="gapping-title">
        <button class="modal-close" type="button" data-close-video-work aria-label="Close selected video work">
          +
        </button>
        <div class="video-work-inner">
          <div class="video-work-copy">
            <p class="work-kicker">Selected Video Work</p>
            <p class="work-title" id="gapping-title">GAPPING</p>
            <div class="work-description">
              <p>
                An experimental dance film co-created with Director AdaQi
                (<a href="https://adaqiying.com/" target="_blank" rel="noreferrer">adaqiying.com</a>),
                it attempts to create a panoramic view of relationship composed of three queering
                individuals that understand, demonstrate, and piece together an visual film through a
                combination of improvised physical theatre and visual exploration.
              </p>
              <p>
                It embodies a Sisyphean alternating climax, originating from the first touch of
                fingertips.
              </p>
              <p>
                The temporal and spatial dislocation in the present moment is not only reflected in
                the delay of actions but also universalizes this experiential difference. The fusion
                and fragmentation of individuals, the connection between subject and self/nature, as
                well as a relationship characterized by ambiguity, specificity, manipulation, gaze,
                and blur, may all be life experiences we possess in different time and space.
              </p>
            </div>
          </div>
          <div class="gapping-posters" aria-label="GAPPING promotional posters">
            <button
              class="poster-lightbox-button"
              type="button"
              data-poster-src="/pic/gapping-crop-1.png"
              data-poster-alt="Two performers in a dim indoor scene pulling against each other, their bodies leaning in opposite directions as if resisting or pushing one another away."
              data-poster-index="0"
              aria-label="GAPPING poster 1"
            >
              <img
                src="/pic/gapping-crop-1.png"
                alt=""
                loading="lazy"
              />
            </button>
            <button
              class="poster-lightbox-button"
              type="button"
              data-poster-src="/pic/gapping-crop-2.jpg"
              data-poster-alt="A wide cinematic frame of two performers seated on the rooftop of an abandoned coal-mining industrial structure, with mountains and warm evening light in the background."
              data-poster-index="1"
              aria-label="GAPPING poster 2"
            >
              <img
                src="/pic/gapping-crop-2.jpg"
                alt=""
                loading="lazy"
              />
            </button>
            <button
              class="poster-lightbox-button"
              type="button"
              data-poster-src="/pic/gapping-crop-3.jpg"
              data-poster-alt="A close-up cinematic frame of a hand reaching toward bright sunlight, with strong lens flare against a dark background."
              data-poster-index="2"
              aria-label="GAPPING poster 3"
            >
              <img
                src="/pic/gapping-crop-3.jpg"
                alt=""
                loading="lazy"
              />
            </button>
          </div>
          <section class="exhibition-info" aria-labelledby="gapping-exhibition-title">
            <h3 id="gapping-exhibition-title">Exhibition</h3>
            <p>NAE OPEN 2026 at the New Art Exchange, Nottingham, UK</p>
            <p>2023 at JinpiFang, Shenzhen, China</p>
          </section>
        </div>
      </dialog>
      <dialog class="poster-lightbox" id="poster-lightbox" aria-label="Enlarged GAPPING poster">
        <button class="lightbox-close" type="button" data-close-poster-lightbox aria-label="Close enlarged poster">
          +
        </button>
        <button class="lightbox-nav poster-prev" type="button" aria-label="Previous poster">&lsaquo;</button>
        <img src="" alt="" />
        <button class="lightbox-nav poster-next" type="button" aria-label="Next poster">&rsaquo;</button>
      </dialog>
    </main>
    <script>
      const contrastButton = document.querySelector(".accessibility-toggle");
      const contrastPreference = localStorage.getItem("high-contrast") === "true";

      const setHighContrast = (enabled) => {
        document.body.classList.toggle("high-contrast", enabled);
        contrastButton?.setAttribute("aria-pressed", String(enabled));
        localStorage.setItem("high-contrast", String(enabled));
      };

      setHighContrast(contrastPreference);

      contrastButton?.addEventListener("click", () => {
        setHighContrast(!document.body.classList.contains("high-contrast"));
      });

      const carousel = document.querySelector(".image-carousel");
      const carouselStatus = document.getElementById("carousel-status");
      let isLoopJumping = false;

      const keepCarouselInLoop = () => {
        if (!(carousel instanceof HTMLElement) || isLoopJumping) {
          return;
        }

        const loopWidth = carousel.scrollWidth / 3;
        if (loopWidth <= 0) {
          return;
        }

        if (carousel.scrollLeft < loopWidth * 0.58) {
          isLoopJumping = true;
          carousel.scrollLeft += loopWidth;
          requestAnimationFrame(() => {
            isLoopJumping = false;
          });
        } else if (carousel.scrollLeft > loopWidth * 1.72) {
          isLoopJumping = true;
          carousel.scrollLeft -= loopWidth;
          requestAnimationFrame(() => {
            isLoopJumping = false;
          });
        }
      };

      const scrollCarousel = (direction) => {
        if (carousel instanceof HTMLElement) {
          carousel.scrollBy({
            left: carousel.clientWidth * 0.82 * direction,
            behavior: "smooth"
          });
          setTimeout(announceCenteredCarouselImage, 220);
        }
      };

      const announceCenteredCarouselImage = () => {
        if (!(carousel instanceof HTMLElement) || !(carouselStatus instanceof HTMLElement)) {
          return;
        }

        const carouselRect = carousel.getBoundingClientRect();
        const carouselCenter = carouselRect.left + carouselRect.width / 2;
        const centeredButton = Array.from(carousel.querySelectorAll(".carousel-image-button")).reduce(
          (closest, button) => {
            if (!(button instanceof HTMLElement)) {
              return closest;
            }

            const buttonRect = button.getBoundingClientRect();
            const buttonCenter = buttonRect.left + buttonRect.width / 2;
            const distance = Math.abs(buttonCenter - carouselCenter);
            if (!closest || distance < closest.distance) {
              return { button, distance };
            }

            return closest;
          },
          null
        );

        const altText = centeredButton?.button.getAttribute("data-lightbox-alt");
        if (altText) {
          carouselStatus.textContent = altText;
        }
      };

      document.querySelector(".carousel-prev")?.addEventListener("click", () => {
        scrollCarousel(-1);
      });
      document.querySelector(".carousel-next")?.addEventListener("click", () => {
        scrollCarousel(1);
      });

      const centerInitialCarouselImage = () => {
        const target = document.querySelector('[data-carousel-focus="true"]');
        if (carousel instanceof HTMLElement && target instanceof HTMLElement) {
          carousel.scrollLeft = target.offsetLeft - (carousel.clientWidth - target.offsetWidth) / 2;
          carousel.classList.remove("is-positioning");
        }
      };

      carousel?.addEventListener(
        "scroll",
        () => {
          requestAnimationFrame(keepCarouselInLoop);
        },
        { passive: true }
      );

      requestAnimationFrame(() => {
        centerInitialCarouselImage();
        announceCenteredCarouselImage();
        setTimeout(centerInitialCarouselImage, 80);
        setTimeout(announceCenteredCarouselImage, 120);
      });

      const lightbox = document.getElementById("life-image-lightbox");
      const lightboxImage = lightbox?.querySelector("img");
      const lightboxCredit = lightbox?.querySelector(".lightbox-credit");
      const lightboxPrev = lightbox?.querySelector(".lightbox-prev");
      const lightboxNext = lightbox?.querySelector(".lightbox-next");
      let activeLightboxImages = [];
      let activeImageIndex = 0;

      const showLightboxImage = (index) => {
        if (!(lightboxImage instanceof HTMLImageElement) || activeLightboxImages.length === 0) {
          return;
        }

        activeImageIndex = (index + activeLightboxImages.length) % activeLightboxImages.length;
        const image = activeLightboxImages[activeImageIndex];
        lightboxImage.src = image.src;
        lightboxImage.alt = image.alt;
        if (lightboxCredit instanceof HTMLElement) {
          lightboxCredit.textContent = image.credit;
        }
      };

      document.addEventListener("click", (event) => {
        const target = event.target;
        const button = target instanceof Element ? target.closest("[data-lightbox-src]") : null;
        if (!button || !(lightbox instanceof HTMLDialogElement)) {
          return;
        }

        const gallery = button.getAttribute("data-lightbox-gallery") || "";
        activeLightboxImages = Array.from(
          document.querySelectorAll(`[data-lightbox-gallery="${gallery}"]`)
        )
          .sort(
            (first, second) =>
              Number(first.getAttribute("data-lightbox-index") || 0) -
              Number(second.getAttribute("data-lightbox-index") || 0)
          )
          .reduce((images, galleryButton) => {
            const src = galleryButton.getAttribute("data-lightbox-src") || "";
            const alt = galleryButton.getAttribute("data-lightbox-alt") || "";
            const credit = galleryButton.getAttribute("data-lightbox-credit") || "";
            if (src && !images.some((image) => image.src === src)) {
              images.push({ src, alt, credit });
            }
            return images;
          }, []);
        showLightboxImage(Number(button.getAttribute("data-lightbox-index") || 0));
        lightbox.showModal();
      });

      lightbox?.addEventListener("click", (event) => {
        if (event.target === lightbox && lightbox instanceof HTMLDialogElement) {
          lightbox.close();
        }
      });

      lightbox?.querySelector(".lightbox-close")?.addEventListener("click", () => {
        if (lightbox instanceof HTMLDialogElement) {
          lightbox.close();
        }
      });

      lightboxPrev?.addEventListener("click", () => {
        showLightboxImage(activeImageIndex - 1);
      });

      lightboxNext?.addEventListener("click", () => {
        showLightboxImage(activeImageIndex + 1);
      });

      document.addEventListener("keydown", (event) => {
        if (!(lightbox instanceof HTMLDialogElement) || !lightbox.open) {
          return;
        }

        if (event.key === "ArrowLeft") {
          showLightboxImage(activeImageIndex - 1);
        }

        if (event.key === "ArrowRight") {
          showLightboxImage(activeImageIndex + 1);
        }
      });

      const gappingModal = document.getElementById("gapping-modal");
      document.querySelector("[data-open-video-work]")?.addEventListener("click", () => {
        if (gappingModal instanceof HTMLDialogElement) {
          gappingModal.showModal();
        }
      });

      gappingModal?.addEventListener("click", (event) => {
        if (event.target === gappingModal && gappingModal instanceof HTMLDialogElement) {
          gappingModal.close();
        }
      });

      document.querySelector("[data-close-video-work]")?.addEventListener("click", () => {
        if (gappingModal instanceof HTMLDialogElement) {
          gappingModal.close();
        }
      });

      const posterLightbox = document.getElementById("poster-lightbox");
      const posterLightboxImage = posterLightbox?.querySelector("img");
      const posterPrev = posterLightbox?.querySelector(".poster-prev");
      const posterNext = posterLightbox?.querySelector(".poster-next");
      const posterImages = Array.from(document.querySelectorAll("[data-poster-src]")).map((button) => ({
        src: button.getAttribute("data-poster-src") || "",
        alt: button.getAttribute("data-poster-alt") || ""
      }));
      let activePosterIndex = 0;

      const showPosterImage = (index) => {
        if (!(posterLightboxImage instanceof HTMLImageElement) || posterImages.length === 0) {
          return;
        }

        activePosterIndex = (index + posterImages.length) % posterImages.length;
        const image = posterImages[activePosterIndex];
        posterLightboxImage.src = image.src;
        posterLightboxImage.alt = image.alt;
      };

      document.addEventListener("click", (event) => {
        const target = event.target;
        const button = target instanceof Element ? target.closest("[data-poster-src]") : null;
        if (!button || !(posterLightbox instanceof HTMLDialogElement)) {
          return;
        }

        showPosterImage(Number(button.getAttribute("data-poster-index") || 0));
        posterLightbox.showModal();
      });

      posterLightbox?.addEventListener("click", (event) => {
        if (event.target === posterLightbox && posterLightbox instanceof HTMLDialogElement) {
          posterLightbox.close();
        }
      });

      document.querySelector("[data-close-poster-lightbox]")?.addEventListener("click", () => {
        if (posterLightbox instanceof HTMLDialogElement) {
          posterLightbox.close();
        }
      });

      posterPrev?.addEventListener("click", () => {
        showPosterImage(activePosterIndex - 1);
      });

      posterNext?.addEventListener("click", () => {
        showPosterImage(activePosterIndex + 1);
      });

      document.addEventListener("keydown", (event) => {
        if (!(posterLightbox instanceof HTMLDialogElement) || !posterLightbox.open) {
          return;
        }

        if (event.key === "ArrowLeft") {
          showPosterImage(activePosterIndex - 1);
        }

        if (event.key === "ArrowRight") {
          showPosterImage(activePosterIndex + 1);
        }
      });

    </script>
  </body>
</html>

